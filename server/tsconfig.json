{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../dist-server",
    "rootDir": ".",
    "allowJs": true,
    "checkJs": false,
    "noEmit": false,
    "strict": true,
    "sourceMap": true,
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["./**/*"],
  "exclude": ["./**/*.test.*", "../dist", "../dist-server", "../node_modules"]
}
